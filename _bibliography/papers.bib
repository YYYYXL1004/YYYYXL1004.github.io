@article{yao2026cagrec,
  abbr         = {ACM MM},
  bibtex_show  = {true},
  title        = {CAGRec: Collaborative-Anchor Guided Multimodal Generative Recommender},
  author       = {Yao, Xianglin and others},
  journal      = {ACM Multimedia 2026},
  year         = {2026},
  abstract     = {Multimodal generative recommendation encodes items into discrete semantic IDs via RQ-VAE and generates recommendations autoregressively. Existing methods face two core challenges: the content-collaborative gap and the discrete-continuous gap. We propose CAGRec, which systematically injects collaborative signals across encoding, training, and inference stages to bridge both gaps. On three Amazon datasets, CAGRec achieves SOTA on all 15 metrics, with NDCG@10 improvements of 2.0%-3.7% over the strongest baseline.},
  selected     = {true},
  code         = {https://github.com/YYYYXL1004/CAGRec},
  additional_info = {Under review at ACM MM 2026 (CCF-A)}
}
